# Environnement virtuel
.venv/
venv/
ENV/

# Configuration sensible (OpenAI keys, etc.)
config/config.yaml
config/prompt.txt
.env

# PyCharm / IDE
.idea/
*.iml

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Données locales (pour ne pas commit les CV de test sur GitHub)
# Ignorer tout le contenu des dossiers data
data/student_labels.csv
data/cv_dataset.csv
data/raw/*
data/extracted/*
data/*

# SAUF les fichiers .gitkeep (pour forcer Git à suivre les dossiers vides)
!data/raw/.gitkeep
!data/extracted/.gitkeep

# Logs
*.log